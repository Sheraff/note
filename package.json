{
  "name": "note",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#web/*": "./web/*",
    "#server/*": "./server/*"
  },
  "scripts": {
    "dev": "node --watch --watch-path=server --watch-path=vite.config.ts --watch-path=vite.server.config.ts --watch-path=index.html --watch-preserve-output server/index.ts --dev",
    "build": "vite build && vite build --config vite.server.config.ts",
    "start": "node dist/server/server.js",
    "check": "tsc -b",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "pnpm build && playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "1.19.12",
    "@vscode/codicons": "0.0.45",
    "hono": "4.12.10",
    "monaco-editor": "0.55.1",
    "solid-js": "1.9.12",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@solidjs/testing-library": "0.8.10",
    "@types/node": "25.5.2",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vite-plugin-solid": "2.11.11",
    "vitest": "4.1.2"
  },
  "packageManager": "pnpm@10.27.0"
}